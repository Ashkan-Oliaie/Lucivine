# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=lucivine
POSTGRES_USER=lucivine
POSTGRES_PASSWORD=lucivine_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email (SendGrid)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@lucivine.app

# Frontend (Vite + SPA)
# For local dev: omit VITE_API_URL — the browser calls http://localhost:5173/api and Vite proxies to Django.
# Never set VITE_API_URL=http://backend:8000 — `backend` only resolves inside Docker networks; use localhost or leave unset.
# Production builds: set VITE_API_URL to your public API origin.
# VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# Internal scheduler — Cloud Scheduler (or local cron) sends this in X-Internal-Secret
INTERNAL_SCHEDULER_SECRET=dev-scheduler-secret

# Web Push (VAPID) — optional in dev.
# Omit VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY: backend generates keys on first use and
# persists them as backend/.vapid.json (Docker mounts ./backend so keys survive restarts).
# For production (multiple replicas / read-only FS), set explicit keys — use `make vapid`.
VAPID_CLAIMS_EMAIL=admin@lucivine.app
