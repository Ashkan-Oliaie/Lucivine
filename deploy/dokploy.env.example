# -----------------------------------------------------------------------------
# Dokploy / split deploy — copy vars into each service as needed.
# Production Compose lives at repo root: docker-compose.yml
# -----------------------------------------------------------------------------

# ========= Backend (Dockerfile target: prod) =========
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=

DJANGO_ALLOWED_HOSTS=api.example.com
DJANGO_DEBUG=False

POSTGRES_DB=lucivine
POSTGRES_USER=lucivine
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

FRONTEND_URL=https://app.example.com

CSRF_TRUSTED_ORIGINS=https://app.example.com
DJANGO_SECURE_SSL_REDIRECT=true

INTERNAL_SCHEDULER_SECRET=

ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

DEFAULT_FROM_EMAIL=noreply@lucivine.app
SENDGRID_API_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@lucivine.app

# Optional: comma-separated — defaults to FRONTEND_URL when unset.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Skip migrations at boot when multiple replicas race — run migrate via CI/job instead.
# SKIP_DB_MIGRATE=1

# -----------------------------------------------------------------------------
# Frontend (Dockerfile target: prod)
#
# Container runs `serve -s dist -l 3000` — configure Dokploy port + healthcheck on / .
#
# Build argument VITE_API_URL:
#   https://api.example.com   ← no trailing slash; must match where the browser reaches your API.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Scheduler (cron / repeat job — NOT the backend container)
#
# Use ANY minimal image with curl (or Dokploy cron). Same INTERNAL_SCHEDULER_SECRET as backend.
#
# BACKEND_PUBLIC_URL=https://api.example.com
#
# Example HTTP command:
# curl -fsS -X POST "${BACKEND_PUBLIC_URL}/api/internal/fire-due-reminders/" \
#   -H "X-Internal-Secret: ${INTERNAL_SCHEDULER_SECRET}"
#
# Interval: every 60–120s is usually enough for reminders (polling-based).
# -----------------------------------------------------------------------------
