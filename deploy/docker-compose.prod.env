# =============================================================================
# Lucivine — production stack (repo-root docker-compose.yml)
#
# Usage:
#   1. Copy this file to the repo root as `.env`, OR paste all KEY=value lines into Dokploy’s env UI.
#   2. Replace every REPLACE_ME_* and example.com value.
#   3. Same-origin `/api` on one hostname: set `VITE_API_URL` to your SPA HTTPS URL (often same as FRONTEND_URL).
#
# Compose reads this file automatically when it sits next to docker-compose.yml as `.env`.
# =============================================================================

# --- Compose substitution (also used by Docker build args / scheduler env) ---
WEB_HTTP_PORT=3001
BACKEND_HTTP_PORT=8000

# Public API origin for Vite build — no trailing slash.
# Split API host: https://api.example.com — or same host as SPA if /api is proxied: https://app.example.com
VITE_API_URL=https://api.example.com

POSTGRES_DB=lucivine
POSTGRES_USER=lucivine
POSTGRES_PASSWORD=REPLACE_ME_DB_PASSWORD

# Must match Django INTERNAL_SCHEDULER_SECRET below (scheduler container uses this via Compose).
INTERNAL_SCHEDULER_SECRET=REPLACE_ME_LONG_RANDOM_SECRET

# --- Django (backend reads via env_file: .env — same keys as above where duplicated) ---
DJANGO_SECRET_KEY=REPLACE_ME_DJANGO_SECRET_KEY_MIN_50_CHARS_RANDOM

DJANGO_ALLOWED_HOSTS=api.example.com
DJANGO_DEBUG=False

POSTGRES_HOST=db
POSTGRES_PORT=5432

FRONTEND_URL=https://app.example.com

CSRF_TRUSTED_ORIGINS=https://app.example.com
DJANGO_SECURE_SSL_REDIRECT=true

ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

DEFAULT_FROM_EMAIL=noreply@lucivine.app
SENDGRID_API_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@lucivine.app

# Optional — comma-separated if multiple SPA origins need API access.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Uncomment only if HTTPS terminates oddly and Django redirects loop (debug carefully).
# DJANGO_SECURE_SSL_REDIRECT=false

# Uncomment when multiple backend replicas run migrations elsewhere (CI/job).
# SKIP_DB_MIGRATE=1
