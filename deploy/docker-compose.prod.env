# docker-compose.yml + `.env` at repo root (or paste these keys wherever Dokploy injects env — same idea).
#
# Postgres stores its password only when `postgres_data` is first created. If you change POSTGRES_PASSWORD in `.env`
# afterward, wipe that Docker volume once or ALTER USER lucivine so it matches — otherwise Django auth fails.

WEB_HTTP_PORT=3001
BACKEND_HTTP_PORT=8000

VITE_API_URL=https://api.example.com

POSTGRES_DB=lucivine
POSTGRES_USER=lucivine
POSTGRES_PASSWORD=REPLACE_ME_DB_PASSWORD

INTERNAL_SCHEDULER_SECRET=REPLACE_ME_LONG_RANDOM_SECRET

DJANGO_SECRET_KEY=REPLACE_ME_DJANGO_SECRET_KEY_MIN_50_CHARS_RANDOM

DJANGO_ALLOWED_HOSTS=.traefik.me,localhost,127.0.0.1
DJANGO_DEBUG=False

POSTGRES_HOST=db
POSTGRES_PORT=5432

FRONTEND_URL=https://app.example.com

CSRF_TRUSTED_ORIGINS=https://app.example.com
DJANGO_SECURE_SSL_REDIRECT=true

ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

DEFAULT_FROM_EMAIL=noreply@lucivine.app
SENDGRID_API_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@lucivine.app

# CORS_ALLOWED_ORIGINS=https://app.example.com
# DJANGO_SECURE_SSL_REDIRECT=false
# SKIP_DB_MIGRATE=1
